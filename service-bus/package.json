{
  "name": "service-bus",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Service Bus — A-GRA Abstract Service Bus (DMS) routing/throughput learning game (headless deterministic core + Svelte/SVG console).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sweep": "tsx tools/run-sweep.ts",
    "dev": "npm run dev -w @service-bus/game",
    "build:game": "npm run build -w @service-bus/game",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^20.11.0",
    "knip": "^6.17.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
