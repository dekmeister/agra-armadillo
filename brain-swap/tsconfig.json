{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@brain-swap/core": ["packages/core/src/index.ts"],
      "@brain-swap/core/*": ["packages/core/src/*"],
      "@brain-swap/levels": ["packages/levels/src/index.ts"],
      "@brain-swap/levels/*": ["packages/levels/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "tools/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["packages/game"]
}
