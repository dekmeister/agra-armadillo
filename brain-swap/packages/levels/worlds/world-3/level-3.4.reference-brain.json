{
  "id": "ref-3.4",
  "_doc": "The capstone: orchestrate FA and MS in one run. Take FA control (the World-1 HSA handshake), command a heading that angles the aircraft into the DLZ, request the DLZ, then run the 3.3 fire + consent chain. MS holds the armed strike at ENABLED until the vehicle is inside the zone, then completes it. Script source only — the player hand-flies all of it.",
  "initial": "await-capability",
  "states": [
    "await-capability",
    "awaiting-approval",
    "confirming-control",
    "flying",
    "dlz-req",
    "tasked",
    "commanded",
    "consented"
  ],
  "transitions": [
    {
      "from": "await-capability",
      "trigger": { "messageType": "MA_FlightCapabilityStatusMT" },
      "guard": { "field": "Availability", "op": "==", "value": "AVAILABLE" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_ControlRequestMT",
          "fields": { "RequestType": "ACQUIRE", "CapabilityID": { "cap": "CapabilityID" } }
        }
      ],
      "target": "awaiting-approval"
    },
    {
      "from": "awaiting-approval",
      "trigger": { "messageType": "MA_ControlRequestStatusMT" },
      "guard": { "field": "ApprovalRequestProcessingState", "op": "==", "value": "APPROVED" },
      "target": "confirming-control"
    },
    {
      "from": "confirming-control",
      "trigger": { "messageType": "ControlStatusMT" },
      "guard": { "field": "SecondaryController", "op": "==", "value": "MA" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "NEW",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 120,
            "Altitude": 3000,
            "Speed": 60
          }
        }
      ],
      "target": "flying"
    },
    {
      "from": "flying",
      "trigger": { "messageType": "MA_FlightCommandStatusMT" },
      "guard": { "field": "CommandProcessingState", "op": "==", "value": "ACCEPTED" },
      "actions": [
        {
          "kind": "send",
          "message": "DLZ_RequestMT",
          "fields": {
            "DLZ_RequestID": "DLZ-1",
            "CapabilityID": "STRIKE-1",
            "ResultsInNativeMessage": true
          }
        }
      ],
      "target": "dlz-req"
    },
    {
      "from": "dlz-req",
      "trigger": { "messageType": "DLZ_MT" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_TaskMT",
          "fields": {
            "TaskID": "TASK-1",
            "TaskType": "STRIKE",
            "Target": "TGT-1",
            "StoreType": "GBU-53",
            "StoreQuantity": 1
          }
        }
      ],
      "target": "tasked"
    },
    {
      "from": "tasked",
      "trigger": { "messageType": "MA_TaskStatusMT" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_TaskCommandMT",
          "fields": { "TaskID": { "msg": "TaskID" }, "CommandState": "NEW" }
        }
      ],
      "target": "commanded"
    },
    {
      "from": "commanded",
      "trigger": { "messageType": "StrikeConsentRequestMT" },
      "actions": [
        {
          "kind": "send",
          "message": "StrikeConsentRequestStatusMT",
          "fields": { "TaskID": { "msg": "TaskID" }, "ConsentState": "APPROVED" }
        }
      ],
      "target": "consented"
    }
  ]
}
