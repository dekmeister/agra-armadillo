      "actions": [
        {
          "kind": "send",
          "message": "MA_TaskMT",
          "fields": {
            "TaskID": "TASK-1",
            "TaskType": "STRIKE",
            "Target": "TGT-1",
            "StoreType": { "msg": "StoreType" },
            "StoreQuantity": 1
          }
        }
      ],
      "target": "tasked"
    },
    {
      "from": "tasked",
      "trigger": { "messageType": "MA_TaskStatusMT" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_TaskCommandMT",
          "fields": { "TaskID": { "msg": "TaskID" }, "CommandState": "NEW" }
        }
      ],
      "target": "commanded"
    },
    {
      "from": "commanded",
      "trigger": { "messageType": "StrikeConsentRequestMT" },
      "actions": [
        {
          "kind": "send",
          "message": "StrikeConsentRequestStatusMT",
