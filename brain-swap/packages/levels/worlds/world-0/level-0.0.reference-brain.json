{
  "id": "ref-0.0",
  "_doc": "Tutorial demo solution (identical to ref-1.2; level 0.0 reuses 1.2's mission verbatim): wait for capability AVAILABLE -> ACQUIRE -> confirm via ControlStatus -> command heading 270/3000 m -> consume position reports to detect arrival -> slow and hold. Used as the script source for level 0.0's watch-only auto-play demo.",
  "initial": "await-capability",
  "states": ["await-capability", "awaiting-approval", "confirming-control", "cruising", "arrived"],
  "transitions": [
    {
      "from": "await-capability",
      "trigger": { "messageType": "MA_FlightCapabilityStatusMT" },
      "guard": { "field": "Availability", "op": "==", "value": "AVAILABLE" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_ControlRequestMT",
          "fields": { "RequestType": "ACQUIRE", "CapabilityID": { "cap": "CapabilityID" } }
        }
      ],
      "target": "awaiting-approval"
    },
    {
      "from": "awaiting-approval",
      "trigger": { "messageType": "MA_ControlRequestStatusMT" },
      "guard": { "field": "ApprovalRequestProcessingState", "op": "==", "value": "APPROVED" },
      "target": "confirming-control"
    },
    {
      "from": "confirming-control",
      "trigger": { "messageType": "ControlStatusMT" },
      "guard": { "field": "SecondaryController", "op": "==", "value": "MA" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "NEW",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 270,
            "Altitude": 3000,
            "Speed": 60
          }
        }
      ],
      "target": "cruising"
    },
    {
      "from": "cruising",
      "trigger": { "messageType": "MA_PositionReportDetailedMT" },
      "guard": { "field": "Longitude", "op": "<=", "value": -600 },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "UPDATE",
            "CapabilityID": { "cap": "CapabilityID" },
            "Speed": 20
          }
        }
      ],
      "target": "arrived"
    }
  ]
}
