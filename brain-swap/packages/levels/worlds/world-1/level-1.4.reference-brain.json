{
  "id": "ref-1.4",
  "_doc": "Handshake, one NEW command to start the circuit, then a Direction-only UPDATE (Heading field only) at each corner threshold. Steering by position guards on Longitude/Latitude.",
  "initial": "await-capability",
  "states": ["await-capability", "awaiting-approval", "confirming-control", "leg-w", "leg-s", "leg-e", "arrived"],
  "transitions": [
    {
      "from": "await-capability",
      "trigger": { "messageType": "MA_FlightCapabilityStatusMT" },
      "guard": { "field": "Availability", "op": "==", "value": "AVAILABLE" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_ControlRequestMT",
          "fields": { "RequestType": "ACQUIRE", "CapabilityID": { "cap": "CapabilityID" } }
        }
      ],
      "target": "awaiting-approval"
    },
    {
      "from": "awaiting-approval",
      "trigger": { "messageType": "MA_ControlRequestStatusMT" },
      "guard": { "field": "ApprovalRequestProcessingState", "op": "==", "value": "APPROVED" },
      "target": "confirming-control"
    },
    {
      "from": "confirming-control",
      "trigger": { "messageType": "ControlStatusMT" },
      "guard": { "field": "SecondaryController", "op": "==", "value": "MA" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "NEW",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 270,
            "Altitude": 3000,
            "Speed": 25
          }
        }
      ],
      "target": "leg-w"
    },
    {
      "from": "leg-w",
      "trigger": { "messageType": "MA_PositionReportDetailedMT" },
      "guard": { "field": "Longitude", "op": "<=", "value": -1200 },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "UPDATE",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 180
          }
        }
      ],
      "target": "leg-s"
    },
    {
      "from": "leg-s",
      "trigger": { "messageType": "MA_PositionReportDetailedMT" },
      "guard": { "field": "Latitude", "op": "<=", "value": -1200 },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "UPDATE",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 90
          }
        }
      ],
      "target": "leg-e"
    },
    {
      "from": "leg-e",
      "trigger": { "messageType": "MA_PositionReportDetailedMT" },
      "guard": { "field": "Longitude", "op": ">=", "value": 0 },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "UPDATE",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 0
          }
        }
      ],
      "target": "arrived"
    }
  ]
}
