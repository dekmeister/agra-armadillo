{
  "id": "naive-1.1",
  "_doc": "Bait brain (teaching artifact, docs/02): jumps straight to commanding flight without acquiring control. FA isn't listening, so the command is ignored-not-controller and the level is never won.",
  "initial": "start",
  "states": ["start", "done"],
  "transitions": [
    {
      "from": "start",
      "trigger": { "messageType": "MA_FlightCapabilityStatusMT" },
      "guard": { "field": "Availability", "op": "==", "value": "AVAILABLE" },
      "actions": [
        {
          "kind": "send",
          "message": "MA_FlightCommandMT",
          "fields": {
            "CommandID": "CMD-1",
            "CommandState": "NEW",
            "CapabilityID": { "cap": "CapabilityID" },
            "Heading": 270,
            "Altitude": 3000,
            "Speed": 60
          }
        }
      ],
      "target": "done"
    }
  ]
}
