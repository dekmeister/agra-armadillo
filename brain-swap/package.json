{
  "name": "brain-swap",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Brain Swap — Zachtronics-style A-GRA Vehicle Interface puzzle (headless MVP core)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:game": "tsc -p packages/game/tsconfig.json --noEmit",
    "gen:catalog": "tsx tools/gen-catalog.ts",
    "fidelity": "tsx tools/check-fidelity.ts",
    "run:1.2": "tsx tools/run-level.ts",
    "test": "vitest run",
    "dev": "npm run dev -w @brain-swap/game",
    "build:game": "npm run build -w @brain-swap/game",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^20.11.0",
    "knip": "^6.17.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "yaml": "^2.4.0"
  }
}
